<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <record id="payment_provider_alipay2" model="payment.provider">
        <field name="name">Alipay</field>
        <field name="code">alipay2</field>
        <field name="image_128" type="base64" file="payment_alipay2/static/description/icon.png"/>
        <field name="module_id" ref="base.module_payment_alipay2"/>
        <field name="redirect_form_view_id" ref="redirect_form"/>
        <field name="available_country_ids" eval="[Command.set([ref('base.cn')])]"/>
        <field name="available_currency_ids" eval="[Command.set([ref('base.CNY')])]"/>
        <field name="payment_method_ids" eval="[Command.set([ref('payment_alipay2.payment_method_alipay2')])]"/>
    </record>
</odoo>
