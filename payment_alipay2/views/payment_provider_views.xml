<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="payment_provider_form" model="ir.ui.view">
        <field name="name">alipay2 Payment Gateway Form</field>
        <field name="model">payment.provider</field>
        <field name="inherit_id" ref="payment.payment_provider_form"/>
        <field name="arch" type="xml">
            <group name="provider_credentials" position="inside">
                <group invisible="code != 'alipay2'">
                    <field name="alipay2_appid" required="code == 'alipay2' and state != 'disabled'"/>
                    <field name="alipay2_app_private_key" required="code == 'alipay2' and state != 'disabled'"/>
                    <field name="alipay2_public_key" required="code == 'alipay2' and state != 'disabled'"/>
                </group>
            </group>
        </field>
    </record>

    <record id="transaction_form_alipay2" model="ir.ui.view">
        <field name="name">alipay2 Transaction Form</field>
        <field name="model">payment.transaction</field>
        <field name="inherit_id" ref="payment.payment_transaction_form"/>
        <field name="arch" type="xml">
            <field name="provider_reference" position="after">
                <field name="alipay2_payment_status" invisible="provider_code != 'alipay2'"/>

                <field name="alipay2_refund_id" invisible="provider_code != 'alipay2'"/>
                <field name="alipay2_refund_amount" invisible="provider_code != 'alipay2'"/>
                <field name="alipay2_refund_currency" invisible="provider_code != 'alipay2'"/>
                <field name="alipay2_refund_createdat" invisible="provider_code != 'alipay2'"/>
            </field>
        </field>
    </record>

</odoo>
